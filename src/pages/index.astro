<style>
  @font-face {
  font-family: "Spotify";
  src: url("/src/pages/fonts/SpotifyMix-Bold.woff2") format("woff2");
  font-weight: normal;
  font-style: normal;
  font-display: swap;
}

  body {
    font-family: Spotify;
    display: flex;
    justify-content: center;
    height: 100vh;
    flex-direction: column;
    font-family: "Spotify", monospace;
    align-items: center;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1em;
    width: 100%;
    align-items: center;
  }

  .inputrow {
  display: flex;
  gap: 8px;
  align-items: flex-end;
  width: 460px;
}

textarea {
  flex: 1;
  resize: none;
  font-size: 14px;
  padding: 12px 16px;
  border: 2px solid #2d2c2c;
  border-radius: 20px;
  outline: none;
  caret-color: #12943f;
}

textarea:focus {
  border-color: #1db954;
}

button {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: 	#1db954;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;

  &:hover {
    transform: scale(1.03);
    transition: ease-in-out;
  }
}

button svg {
  width: 16px;
  height: 16px;
  fill: white;
}

  p {
    font-size: 1.2rem;
  }

  .tracks {
  display: flex;
  gap: 1rem;
}

.track-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  color: inherit;
  width: 140px;
}

.track-card img {
  width: 140px;
  height: 140px;
  border-radius: 8px;
}

.track-card span {
  font-size: 13px;
  text-align: center;
}

.track-card:hover span {
  color: #1db954;
}
</style>

<!-- Hulp van Jad -->
<script>
    // @ts-nocheck
const form = document.querySelector("form");
const textarea = document.querySelector("textarea");
const aiAnswer = document.querySelector("p");
const iconPlay = document.getElementById("iconPlay");
const iconPause = document.getElementById("iconPause");

function setPlaying(playing) {
  iconPlay.style.display = playing ? "none" : "block";
  iconPause.style.display = playing ? "block" : "none";
}

form.addEventListener("submit", async (e) => {
  e.preventDefault();
  const userInput = textarea.value;
  if (!userInput) {
    aiAnswer.innerHTML = "Zonder enige input kan ik helaas niks voor je vinden.."
    return;
  }

  setPlaying(true);
  aiAnswer.textContent = "Even zoeken...";

  if ('LanguageModel' in self) {
    const session = await LanguageModel.create({
      initialPrompts: [{
        role: "system",
        content: "Je geeft drie muziek artiesten terug gebaseerd op wat de gebruiker als input geeft, alleen de artiesten namen en niks anders. Als de gebruiker een muziekartiest op geeft geef dan drie artiesten die vergelijkbare muziek hebben. Gebruik geen markdown of andere opmaak in je berichten. Als je niks uit de user input kan halen en/of de opgegeven input is een naam maar geen spotify artiest zeg dan aan: Sorry hier kan ik geen artiesten uit halen, probeer wat anders!"
      }]
    });
    const result = await session.prompt(userInput);
    aiAnswer.innerHTML = result;
    session.destroy();
  } else {
    setPlaying(false);
    const response = await fetch(`/api?artist=${userInput}`);
    const data = await response.json();
    aiAnswer.innerHTML = data.answer;
  }

});

    
</script>





